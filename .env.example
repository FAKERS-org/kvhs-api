# Database Configuration
DATABASE_URL=postgresql://kvhs:kvhs@localhost:5432/kvhs
AUTO_CREATE_TABLES=true
# For MySQL: DATABASE_URL=mysql+pymysql://user:password@localhost/kvhs
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost/kvhs

# MinIO Configuration (for file storage - replaces GridFS)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=kvhs-files
MINIO_SECURE=false

# Security Settings
SECRET_KEY=1234567890abcdef
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Settings (comma-separated list)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# File Upload Settings
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes

# MongoDB Settings (deprecated - being migrated to PostgreSQL)
MONGODB_URL=mongodb://username:password@localhost:27017/kvhs?authSource=admin
MONGODB_DB_NAME=kvhs

